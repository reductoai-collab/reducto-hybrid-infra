# =============================================================================
# Example Backend Configuration
# =============================================================================
# Uncomment and configure one of the following backend options to store
# Terraform state remotely. This is recommended for team environments.
# =============================================================================

# -----------------------------------------------------------------------------
# Option 1: S3 Backend (Recommended for AWS)
# -----------------------------------------------------------------------------
# terraform {
#   backend "s3" {
#     bucket         = "your-terraform-state-bucket"
#     key            = "reducto-hybrid-infra/terraform.tfstate"
#     region         = "us-east-1"
#     encrypt        = true
#     dynamodb_table = "terraform-state-lock"  # Optional: for state locking
#   }
# }

# -----------------------------------------------------------------------------
# Option 2: Terraform Cloud
# -----------------------------------------------------------------------------
# terraform {
#   cloud {
#     organization = "your-organization"
#     workspaces {
#       name = "reducto-hybrid-infra"
#     }
#   }
# }

# -----------------------------------------------------------------------------
# Option 3: Local Backend (Default, not recommended for production)
# -----------------------------------------------------------------------------
# No configuration needed - Terraform uses local state by default.
# State will be stored in terraform.tfstate in the current directory.
